# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Safepay (Pakistan Payment Gateway) ─────────────
# Get from: getsafepay.com → Developer → API Keys
SAFEPAY_API_KEY=your_safepay_api_key
SAFEPAY_SECRET_KEY=your_safepay_secret_key
SAFEPAY_WEBHOOK_SECRET=your_safepay_webhook_secret
NEXT_PUBLIC_SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_STARTER_PLAN_ID=plan_xxx
SAFEPAY_PRO_PLAN_ID=plan_xxx
SAFEPAY_BUSINESS_PLAN_ID=plan_xxx

# ─── Resend (Email) ──────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@medpos.pk
ADMIN_EMAIL=admin@medpos.pk

# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.medpos.pk
APP_SECRET=minimum-32-character-random-secret-here
CRON_SECRET=random-secret-for-cron-protection
ADMIN_INITIAL_PASSWORD=change_this_immediately_after_first_login

# ─── Crisp (Support Chat) ────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxx

# ─── Sentry ──────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── PostHog ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
